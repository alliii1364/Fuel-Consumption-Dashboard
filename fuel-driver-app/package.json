{
  "name": "fuel-driver-app",
  "version": "0.1.0",
  "private": true,
  "description": "FuelIQ Driver — Capacitor Android shell wrapping the /driver PWA",
  "scripts": {
    "build:web": "cd ../fuel-dashboard && CAP_BUILD=1 NEXT_PUBLIC_API_URL=\"${NEXT_PUBLIC_API_URL:-https://ifs.itecknologi.com}\" npm run build",
    "sync:web": "node scripts/prepare-www.mjs && npx cap sync android",
    "build": "npm run build:web && npm run sync:web",
    "open": "npx cap open android",
    "apk:debug": "cd android && ./gradlew assembleDebug"
  },
  "dependencies": {
    "@capacitor-community/background-geolocation": "^1.2.26",
    "@capacitor/android": "^6.2.0",
    "@capacitor/camera": "^6.1.3",
    "@capacitor/core": "^6.2.0",
    "@capacitor/geolocation": "^6.1.1",
    "@capacitor/network": "^6.0.4",
    "@capacitor/preferences": "^6.0.4",
    "@capacitor/push-notifications": "^6.0.5"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.2.0",
    "typescript": "^6.0.3"
  }
}
