{
  "info": {
    "name": "Fuel Consumption Dashboard API",
    "description": "Complete API collection for the Vehicle Fuel Consumption Dashboard backend built with NestJS.",
    "_postman_id": "fuel-dashboard-api-v2",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:3000", "type": "string" },
    { "key": "token",    "value": "", "type": "string", "description": "JWT token — auto-set after login" },
    { "key": "imei",     "value": "47395226", "type": "string", "description": "JV-6213 vehicle IMEI" },
    { "key": "from",     "value": "2026-04-01T00:00:00Z", "type": "string" },
    { "key": "to",       "value": "2026-04-10T23:59:59Z", "type": "string" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/health", "host": ["{{base_url}}"], "path": ["health"] },
            "description": "Check if the server is running. No authentication required."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"message\": \"Service is healthy\",\n  \"data\": { \"status\": \"ok\", \"timestamp\": \"2026-04-10T09:44:02.548Z\" }\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.success && json.data && json.data.token) {",
                  "    pm.collectionVariables.set('token', json.data.token);",
                  "    console.log('Token saved:', json.data.token.substring(0, 30) + '...');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"your_password_here\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"] },
            "description": "Login with username/password. JWT token is automatically saved to `token` variable."
          },
          "response": [
            {
              "name": "200 Login Success",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"message\": \"Login successful\",\n  \"data\": { \"token\": \"eyJhbGci...\", \"expiresIn\": \"24h\" }\n}"
            },
            {
              "name": "401 Invalid Credentials",
              "status": "Unauthorized",
              "code": 401,
              "body": "{\n  \"success\": false,\n  \"message\": \"Invalid username or password\",\n  \"error\": \"UnauthorizedException\",\n  \"statusCode\": 401\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Vehicles",
      "item": [
        {
          "name": "List All Vehicles",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/vehicles", "host": ["{{base_url}}"], "path": ["vehicles"] },
            "description": "Returns all vehicles linked to the logged-in user including GPS, speed, lastSeen and online/offline status."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"message\": \"Vehicles fetched successfully\",\n  \"data\": {\n    \"count\": 1,\n    \"vehicles\": [\n      { \"imei\": \"47395226\", \"name\": \"JV-6213\", \"plateNumber\": \"JV-6213\", \"speed\": 0, \"lat\": 31.5497, \"lng\": 74.3436, \"lastSeen\": \"2026-04-10T09:10:00Z\", \"status\": \"online\", \"device\": \"\", \"model\": \"\", \"simNumber\": \"\" }\n    ]\n  }\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Fuel (Per Vehicle)",
      "item": [
        {
          "name": "List Fuel Sensors",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/vehicles/{{imei}}/fuel/sensors",
              "host": ["{{base_url}}"],
              "path": ["vehicles", "{{imei}}", "fuel", "sensors"]
            },
            "description": "List all fuel sensors for this vehicle. Use returned `sensorId` in other endpoints via `?sensorId=` for multi-tank vehicles."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"message\": \"1 fuel sensor(s) found\",\n  \"data\": {\n    \"imei\": \"47395226\",\n    \"count\": 1,\n    \"sensors\": [\n      { \"sensorId\": 24321, \"name\": \"Fuel\", \"type\": \"fuel\", \"param\": \"fuel1\", \"units\": \"L\", \"formula\": null, \"hasCalibration\": true }\n    ]\n  }\n}"
            }
          ]
        },
        {
          "name": "Current Fuel Level",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/vehicles/{{imei}}/fuel/current",
              "host": ["{{base_url}}"],
              "path": ["vehicles", "{{imei}}", "fuel", "current"],
              "query": [
                { "key": "sensorId", "value": "", "description": "Optional: specific tank sensorId", "disabled": true }
              ]
            },
            "description": "Latest fuel level. Applies formula or calibration to raw sensor value."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"message\": \"Current fuel level fetched\",\n  \"data\": {\n    \"imei\": \"47395226\",\n    \"totalFuel\": 316.28,\n    \"unit\": \"L\",\n    \"tanks\": [ { \"sensorId\": 24321, \"sensorName\": \"Fuel\", \"fuel\": 316.28, \"unit\": \"L\", \"method\": \"calibration\" } ],\n    \"lastSeen\": \"2026-04-10T08:30:50.000Z\",\n    \"speed\": 0,\n    \"lat\": 31.5497,\n    \"lng\": 74.3436\n  }\n}"
            },
            {
              "name": "403 Not Your Vehicle",
              "status": "Forbidden",
              "code": 403,
              "body": "{\n  \"success\": false,\n  \"message\": \"You do not have permission to access this vehicle\",\n  \"error\": \"ForbiddenException\",\n  \"statusCode\": 403\n}"
            }
          ]
        },
        {
          "name": "Fuel History — 15min",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/vehicles/{{imei}}/fuel/history?from={{from}}&to={{to}}&interval=15min",
              "host": ["{{base_url}}"],
              "path": ["vehicles", "{{imei}}", "fuel", "history"],
              "query": [
                { "key": "from", "value": "{{from}}" },
                { "key": "to", "value": "{{to}}" },
                { "key": "interval", "value": "15min", "description": "5min | 15min | hour | day" },
                { "key": "tz", "value": "Asia/Karachi", "description": "IANA timezone for output timestamps", "disabled": true },
                { "key": "sensorId", "value": "", "disabled": true }
              ]
            },
            "description": "Fuel level time series. DB-level bucketing — no data loss on long ranges.\n\nIntervals: `5min`, `15min`, `hour`, `day`\nAuto-selected if not given:\n- ≤1 day → 5min\n- 1-7 days → 15min\n- 7-30 days → hour\n- >30 days → day"
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"message\": \"Fuel history fetched successfully\",\n  \"data\": {\n    \"imei\": \"47395226\",\n    \"from\": \"2026-04-01T00:00:00.000Z\",\n    \"to\": \"2026-04-10T23:59:59.000Z\",\n    \"interval\": \"15min\",\n    \"unit\": \"L\",\n    \"samples\": 441,\n    \"sensorId\": 24321,\n    \"sensorName\": \"Fuel\",\n    \"buckets\": [\n      { \"dt\": \"2026-04-06T00:00:00.000Z\", \"fuel\": 161.63, \"unit\": \"L\" },\n      { \"dt\": \"2026-04-06T00:15:00.000Z\", \"fuel\": 160.20, \"unit\": \"L\" }\n    ]\n  }\n}"
            }
          ]
        },
        {
          "name": "Fuel History — Hour",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/vehicles/{{imei}}/fuel/history?from={{from}}&to={{to}}&interval=hour",
              "host": ["{{base_url}}"],
              "path": ["vehicles", "{{imei}}", "fuel", "history"],
              "query": [
                { "key": "from", "value": "{{from}}" },
                { "key": "to", "value": "{{to}}" },
                { "key": "interval", "value": "hour" }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Fuel History — Day",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/vehicles/{{imei}}/fuel/history?from={{from}}&to={{to}}&interval=day",
              "host": ["{{base_url}}"],
              "path": ["vehicles", "{{imei}}", "fuel", "history"],
              "query": [
                { "key": "from", "value": "{{from}}" },
                { "key": "to", "value": "{{to}}" },
                { "key": "interval", "value": "day" }
