          "name": "Fuel Consumption Summary",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/vehicles/{{imei}}/fuel/consumption?from={{from}}&to={{to}}",
              "host": ["{{base_url}}"],
              "path": ["vehicles", "{{imei}}", "fuel", "consumption"],
              "query": [
                { "key": "from", "value": "{{from}}" },
                { "key": "to", "value": "{{to}}" },
                { "key": "sensorId", "value": "", "description": "Optional: specific tank", "disabled": true }
              ]
            },
            "description": "Total consumed, refueled, cost + all drop & refuel events.\n\nAlgorithm: delta < -0.5L → drop, delta > +3.0L → refuel, |delta| ≤ 0.5L → noise."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"message\": \"Fuel consumption calculated\",\n  \"data\": {\n    \"imei\": \"47395226\",\n    \"from\": \"2026-04-01T00:00:00.000Z\",\n    \"to\": \"2026-04-10T23:59:59.000Z\",\n    \"consumed\": 210.5,\n    \"refueled\": 581.64,\n    \"estimatedCost\": null,\n    \"unit\": \"L\",\n    \"refuelEvents\": 3,\n    \"samples\": 4502,\n    \"drops\": [ { \"at\": \"2026-04-06T07:15:00Z\", \"fuelBefore\": 356.79, \"fuelAfter\": 354.12, \"consumed\": 2.67, \"unit\": \"L\" } ],\n    \"refuels\": [\n      { \"at\": \"2026-04-06T07:27:42Z\", \"fuelBefore\": 161.63, \"fuelAfter\": 356.79, \"added\": 195.16, \"unit\": \"L\" },\n      { \"at\": \"2026-04-08T13:49:23Z\", \"fuelBefore\": 128.95, \"fuelAfter\": 350.88, \"added\": 221.93, \"unit\": \"L\" },\n      { \"at\": \"2026-04-10T05:25:59Z\", \"fuelBefore\": 188.91, \"fuelAfter\": 353.66, \"added\": 164.75, \"unit\": \"L\" }\n    ]\n  }\n}"
            }
          ]
        },
