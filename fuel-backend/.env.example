# Copy this file to `.env` and fill in real values. NEVER commit `.env`.

# --- Database (MySQL) ---
DB_HOST=your-db-host
DB_PORT=3306
DB_USER=your-db-user
DB_PASSWORD=your-db-password
DB_NAME=your-db-name

# --- Auth ---
# Generate a strong, unique secret, e.g.:  openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=24h

# --- Server ---
PORT=3007
STALE_THRESHOLD_MINUTES=30

# --- CORS ---
# Production: comma-separated allowlist of dashboard origins.
# Leave empty in local dev to allow all origins.
CORS_ORIGINS=

# --- Routing engine (OSRM) ---
# Public demo is TESTING ONLY (rate-limited, no SLA). Self-host for production.
OSRM_URL=http://localhost:5000

# --- Uploads ---
# Directory for driver proof-of-delivery photos. In production point this at a
# persistent volume so photos survive redeploys (default: <cwd>/uploads).
# UPLOADS_DIR=/var/data/fueliq/uploads
